# Server configurations
PORT=5000
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=http://localhost:5173

# MongoDB URI connection string
# Replace with your actual Atlas connection or local string
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/inventra?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/inventra

# Email SMTP configuration for password reset emails
# Example provider values for Mailtrap, SendGrid, or SMTP servers
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_password
EMAIL_FROM=no-reply@inventra.com
